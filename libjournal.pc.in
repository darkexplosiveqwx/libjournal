prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: libjournal
Description: C library for writing to systemd journald without libsystemd
Version: @PROJECT_VERSION@
Libs: -L${libdir} -ljournal -pthread
Cflags: -I${includedir}
